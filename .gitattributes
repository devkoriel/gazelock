# Core ML packages — tracked via LFS (large binary weights)
*.mlpackage filter=lfs diff=lfs merge=lfs -text
*.mlmodel filter=lfs diff=lfs merge=lfs -text
*.mlmodelc filter=lfs diff=lfs merge=lfs -text

# PyTorch checkpoints (used during training; released weights only)
*.pt filter=lfs diff=lfs merge=lfs -text
*.pth filter=lfs diff=lfs merge=lfs -text

# Model-weight binary blobs
weights/*.bin filter=lfs diff=lfs merge=lfs -text
